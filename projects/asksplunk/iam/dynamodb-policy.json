{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBSessionManagement",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:eu-west-1:483013340174:table/splunk-bot-sessions",
        "arn:aws:dynamodb:eu-west-1:483013340174:table/splunk-bot-sessions/index/usage-by-timestamp",
        "arn:aws:dynamodb:eu-west-1:483013340174:table/splunk-bot-sessions/index/survey-by-type"
      ]
    }
  ]
}
