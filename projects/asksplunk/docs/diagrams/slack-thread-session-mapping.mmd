flowchart LR
    subgraph Slack["💬 Slack"]
        MSG[Message]
        NEW[New thread<br/>uses ts]
        REPLY[Reply<br/>uses thread_ts]
    end

    subgraph Session["💾 DynamoDB"]
        KEY[thread_id = key]
        TTL[30 min TTL]
        DEL[Persists for follow-ups<br/>until TTL]
    end

    MSG --> NEW
    MSG --> REPLY
    NEW --> KEY
    REPLY --> KEY
    KEY --> TTL
    TTL --> DEL

    style Slack fill:#E1BEE7,stroke:#7B1FA2
    style Session fill:#FFE0B2,stroke:#F57C00
