# Jira MCP Server Configuration
# Mode: "ipaas" (production) or "direct" (local dev)
USE_IPAAS=true

# iPaaS Mode
JIRA_API_BASE_URL=https://ipaasapi.adobe-services.com/jira/rest/api/2
JIRA_API_KEY=
JIRA_IMS_TOKEN=
JIRA_PAT=

# Direct Mode
# JIRA_API_BASE_URL=https://jira.corp.adobe.com/rest/api/2
# JIRA_PAT=your-personal-access-token

# AWS Secrets Manager (production)
USE_AWS_SECRETS=false
AWS_REGION=eu-west-1
AWS_PROFILE=campaign_prod_v7

# Server
PORT=8081
