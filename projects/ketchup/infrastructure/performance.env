# Performance tuning environment variables for Ketchup services
# Used via env_file directive in docker-compose.yml

# Keep-Alive Connection Tuning - Optimize HTTP connection reuse (2-3% performance gain)
KETCHUP_KEEPALIVE_ENABLED=true
KETCHUP_KEEPALIVE_TIMEOUT=60
KETCHUP_DNS_CACHE_TTL=300

# HTTP/2 Migration Settings (5-8% performance gain)
KETCHUP_USE_HTTPX=true
KETCHUP_HTTP2_ENABLED=true
KETCHUP_HTTPX_POOL_LIMITS=50

# Pipeline Processing (59% performance improvement)
USE_PIPELINE_PROCESSING=true

# Structured JSON Output - Enable JSON mode for 10-20% faster AI responses
KETCHUP_STRUCTURED_JSON_OUTPUT=true
