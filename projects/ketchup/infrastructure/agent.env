# Ketchup Agent Feature Flags and Configuration
# Controls vector search, RAG pipeline, and embedding operations

# Master switches for agent functionality
KETCHUP_AGENT_ENABLED=false
KETCHUP_AGENT_BACKFILL_ENABLED=false

# ChromaDB Connection Configuration
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# Backfill Configuration
# Maximum messages to backfill per channel (default 50000 in code)
KETCHUP_AGENT_MAX_BACKFILL_MESSAGES=50000

# RAG Pipeline Configuration
# top_k: number of results from vector store (pure cosine similarity)
KETCHUP_AGENT_TOP_K=20
KETCHUP_AGENT_MAX_HISTORY_TURNS=10
KETCHUP_AGENT_TEMPERATURE=0.3
KETCHUP_AGENT_MAX_TOKENS=2048
