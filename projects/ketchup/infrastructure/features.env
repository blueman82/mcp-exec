# Feature flags for Ketchup services
# Loaded by ketchup-app and ketchup-unified-scheduler
# Production values — override in docker-compose.local.yml for dev

# Status Updater
KETCHUP_STATUS_UPDATER_FEATURE=true
KETCHUP_STATUS_UPDATER_GLOBAL=true
KETCHUP_STATUS_UPDATER_ENABLED=true

# JIRA Reporter
KETCHUP_JIRA_REPORTER_FEATURE=true
KETCHUP_JIRA_REPORTER_GLOBAL=true

# Metadata Updater
KETCHUP_METADATA_UPDATER_FEATURE=true

# Maintenance
KETCHUP_MAINTENANCE_FETCHER_ENABLED=true
KETCHUP_MAINTENANCE_DETECTION=true

# JIRA PAT Rotator
KETCHUP_JIRA_PAT_ROTATOR_FEATURE=true

# Trust Endorsement
KETCHUP_TRUST_ENDORSEMENT_FEATURE=true
KETCHUP_TRUST_ENDORSEMENT_GLOBAL=true

# Access Request Automation
KETCHUP_ACCESS_REQUEST_AUTOMATION_FEATURE=true
KETCHUP_ACCESS_REQUEST_AUTOMATION_GLOBAL=true

# User Join Notifications
KETCHUP_USER_JOIN_NOTIFICATIONS_FEATURE=true
KETCHUP_USER_JOIN_NOTIFICATIONS_GLOBAL=true

# Handover Summary
KETCHUP_HANDOVER_SUMMARY_ENABLED=false
KETCHUP_HANDOVER_TARGET_CHANNEL=C03PWLW9P5H
KETCHUP_HANDOVER_SCHEDULE_TIMES=09:00,17:00
KETCHUP_HANDOVER_MESSAGE_WINDOW_HOURS=12

# Channel Exclusions
EXCLUDED_CSO_CHANNELS=C090V88CB1N,C08CQN1JCSC,C03PWLW9P5H

# ChromaDB Data Layer (independent of agent)
KETCHUP_CHROMADB_ENABLED=false
