# CSOPM Notifier configuration
# Loaded by ketchup-csopm-notifier only
# Production values — override in docker-compose.local.yml for dev

# Feature flag
KETCHUP_CSOPM_NOTIFIER_ENABLED=true

# DynamoDB table for state tracking
CSOPM_DYNAMODB_TABLE=ketchup_channel_information

# JIRA project and reminder thresholds
CSOPM_JIRA_PROJECT=CSOPM
CSOPM_RCA_REMINDER_DAYS=7
CSOPM_CLOSURE_REMINDER_DAYS=45
CSOPM_MAX_PING_COUNT=3

# Schedule (UTC times)
CSOPM_SCHEDULE_TIMES=08:00,12:00,14:00,16:00,20:00,00:00

# Pilot users for initial rollout (empty = all users)
CSOPM_PILOT_SLACK_IDS=WDGLSLQRK,W5H6R82Q6,WDHGPEL2K,W4RT2F744,W74KBA6SG,W6YLR99EJ,W4R4RGY4Q,W7MGASQ2K
