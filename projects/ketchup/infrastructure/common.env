# Common environment variables shared across all Ketchup services
# Used via env_file directive in docker-compose.yml

# AWS Configuration
AWS_REGION=eu-west-1
DYNAMODB_TABLE_NAME=ketchup_channel_information
AWS_SECRET_NAME=Ketchup_Token_Secrets

# Application Settings
LOG_LEVEL=INFO
PYTHONPATH=/app
MAX_CONCURRENT_REQUESTS=20
