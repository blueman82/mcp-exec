# Azure OpenAI and JIRA tool configuration
# Loaded by ketchup-app and ketchup-unified-scheduler

# Azure OpenAI
OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_ENDPOINT=https://ketchup-prod1.openai.azure.com/openai/deployments/gpt-4.1/chat/completions?api-version=2025-01-01-preview

# JIRA Tool Corrections Cache
JIRA_TOOL_PERSIST_CORRECTIONS=true
JIRA_TOOL_CORRECTIONS_FILE=/tmp/jira_corrections_cache.json
