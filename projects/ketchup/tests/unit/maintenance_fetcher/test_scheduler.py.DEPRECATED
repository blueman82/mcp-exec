"""Unit tests for maintenance fetcher scheduler module."""

import asyncio
import signal
from datetime import datetime
from unittest.mock import AsyncMock, Mock, patch

import pytest

# Import scheduler module at the top
from maintenance_fetcher.scheduler import (
    MaintenanceFetcherScheduler,
    async_main,
    main,
)


def test_scheduler_init():
    """Test scheduler initialization."""
    with patch("signal.signal") as mock_signal, patch("os.getenv") as mock_getenv:

        mock_getenv.return_value = "false"

        scheduler = MaintenanceFetcherScheduler()

        # Assert
        assert scheduler.running is True
        assert scheduler.TARGET_HOUR == 1
        assert scheduler.TARGET_MINUTE == 30
        assert scheduler.run_on_start is False
        assert str(scheduler.health_file) == "/app/health/maintenance_fetcher_health"
        assert (
            str(scheduler.last_run_file) == "/app/health/maintenance_fetcher_last_run"
        )

        # Verify signal handlers registered
        assert mock_signal.call_count == 2
        mock_signal.assert_any_call(signal.SIGTERM, scheduler._signal_handler)
        mock_signal.assert_any_call(signal.SIGINT, scheduler._signal_handler)


def test_scheduler_init_with_run_on_start():
    """Test scheduler initialization with RUN_ON_START=true."""
    with patch("signal.signal"), patch("os.getenv") as mock_getenv:

        mock_getenv.return_value = "true"

        scheduler = MaintenanceFetcherScheduler()

        assert scheduler.run_on_start is True


def test_signal_handler_sigterm():
    """Test SIGTERM signal handler."""
    with patch("signal.signal"), patch("os.getenv"):

        scheduler = MaintenanceFetcherScheduler()
        scheduler.running = True

        # Call signal handler
        scheduler._signal_handler(signal.SIGTERM, None)

        # Assert
        assert scheduler.running is False


def test_signal_handler_sigint():
    """Test SIGINT signal handler."""
    with patch("signal.signal"), patch("os.getenv"):

        scheduler = MaintenanceFetcherScheduler()
        scheduler.running = True

        # Call signal handler
        scheduler._signal_handler(signal.SIGINT, None)

        # Assert
        assert scheduler.running is False


def test_update_health_status():
    """Test health status file writing."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "time.time"
    ) as mock_time, patch("pathlib.Path.write_text") as mock_write, patch(
        "pathlib.Path.mkdir"
    ):

        mock_time.return_value = 1696464000.0

        scheduler = MaintenanceFetcherScheduler()
        scheduler._update_health_status("idle")

        # Assert
        mock_write.assert_called_once_with("1696464000:idle")


def test_update_health_status_exception_handling():
    """Test health status update handles exceptions gracefully."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "pathlib.Path.write_text"
    ) as mock_write:

        mock_write.side_effect = OSError("Permission denied")

        scheduler = MaintenanceFetcherScheduler()

        # Should not raise exception
        scheduler._update_health_status("idle")


