@pytest.mark.asyncio
async def test_start_with_immediate_shutdown():
    """Test scheduler start with immediate shutdown signal."""
    with patch("signal.signal"), patch("os.getenv"):

        scheduler = MaintenanceFetcherScheduler()
        scheduler.running = False  # Simulate immediate shutdown

        # Mock methods
        scheduler._update_health_status = Mock()
        scheduler._run_initial_fetch_if_enabled = AsyncMock()
        scheduler._seconds_until_target_time = Mock(return_value=100)

        await scheduler.start()

        # Assert
        scheduler._update_health_status.assert_any_call("starting")
        scheduler._update_health_status.assert_any_call("stopped")


@pytest.mark.asyncio
async def test_start_with_short_wait():
    """Test scheduler with short wait time (less than 60 seconds)."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "asyncio.sleep"
    ) as mock_sleep:

        scheduler = MaintenanceFetcherScheduler()

        # Mock methods
        scheduler._update_health_status = Mock()
        scheduler._run_initial_fetch_if_enabled = AsyncMock()
        scheduler.run_maintenance_fetch = AsyncMock()

        # Return 45 seconds, then trigger shutdown
        call_count = [0]

        def seconds_side_effect():
            call_count[0] += 1
            if call_count[0] == 1:
                return 45  # First call: 45 seconds until run
            scheduler.running = False  # Shutdown after first iteration
            return 0

        scheduler._seconds_until_target_time = Mock(side_effect=seconds_side_effect)

        await scheduler.start()

        # Assert - should sleep 45 seconds (no 60s chunks)
        mock_sleep.assert_called_once_with(45)
        scheduler.run_maintenance_fetch.assert_called_once()


@pytest.mark.asyncio
async def test_start_with_cancelled_error():
    """Test scheduler handles asyncio.CancelledError."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "asyncio.sleep"
    ) as mock_sleep:

        mock_sleep.side_effect = asyncio.CancelledError()

        scheduler = MaintenanceFetcherScheduler()

        # Mock methods
        scheduler._update_health_status = Mock()
        scheduler._run_initial_fetch_if_enabled = AsyncMock()
        scheduler._seconds_until_target_time = Mock(return_value=3600)

        await scheduler.start()

        # Assert - should handle cancellation gracefully
        scheduler._update_health_status.assert_any_call("stopped")


@pytest.mark.asyncio
async def test_start_with_exception_in_loop():
    """Test scheduler handles exceptions in main loop."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "asyncio.sleep"
    ) as mock_sleep:

        # First call raises exception, second call succeeds, third call stops
        call_count = [0]

        async def sleep_side_effect(seconds):
            call_count[0] += 1
            if call_count[0] == 1:
                raise Exception("Network error")
            elif call_count[0] == 2:
                return  # Normal sleep
            else:
                raise asyncio.CancelledError()  # Stop after recovery

        mock_sleep.side_effect = sleep_side_effect

        scheduler = MaintenanceFetcherScheduler()

        # Mock methods
        scheduler._update_health_status = Mock()
        scheduler._run_initial_fetch_if_enabled = AsyncMock()
        scheduler._seconds_until_target_time = Mock(return_value=60)

        await scheduler.start()

        # Assert - should recover from exception
        assert call_count[0] >= 2  # At least 2 attempts


@pytest.mark.asyncio
async def test_async_main():
    """Test async_main entry point."""
    with patch(
        "maintenance_fetcher.scheduler.MaintenanceFetcherScheduler"
    ) as MockScheduler:

        mock_scheduler_instance = Mock()
        mock_scheduler_instance.start = AsyncMock()
        MockScheduler.return_value = mock_scheduler_instance

        await async_main()

        # Assert
        MockScheduler.assert_called_once()
        mock_scheduler_instance.start.assert_called_once()


def test_main_entry_point_success():
    """Test main() entry point successful execution."""
    with patch("asyncio.run") as mock_run:

        main()

        # Assert
        mock_run.assert_called_once()


def test_main_entry_point_keyboard_interrupt():
    """Test main() handles KeyboardInterrupt gracefully."""
    with patch("asyncio.run") as mock_run:

        mock_run.side_effect = KeyboardInterrupt()

        # Should not raise exception
        main()


def test_main_entry_point_exception():
    """Test main() raises exceptions from async_main."""
    with patch("asyncio.run") as mock_run:

        mock_run.side_effect = RuntimeError("Fatal error")

        # Should raise the exception
        with pytest.raises(RuntimeError, match="Fatal error"):
            main()
