def test_seconds_until_target_time_before():
    """Test time calculation when before 1:30 AM today."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "maintenance_fetcher.scheduler.datetime"
    ) as mock_datetime:

        # Mock current time: 2025-10-06 00:00:00 UTC (before 1:30 AM)
        mock_now = datetime(2025, 10, 6, 0, 0, 0)
        mock_datetime.utcnow.return_value = mock_now

        scheduler = MaintenanceFetcherScheduler()
        seconds = scheduler._seconds_until_target_time()

        # Assert - should be 1.5 hours = 5400 seconds
        assert seconds == 5400


def test_seconds_until_target_time_after():
    """Test time calculation when after 1:30 AM (should be tomorrow)."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "maintenance_fetcher.scheduler.datetime"
    ) as mock_datetime:

        # Mock current time: 2025-10-06 02:00:00 UTC (after 1:30 AM)
        mock_now = datetime(2025, 10, 6, 2, 0, 0)
        mock_datetime.utcnow.return_value = mock_now

        scheduler = MaintenanceFetcherScheduler()
        seconds = scheduler._seconds_until_target_time()

        # Assert - should be 23.5 hours = 84600 seconds
        assert seconds == 84600


def test_seconds_until_target_time_exact():
    """Test time calculation when exactly at 1:30 AM (should be tomorrow)."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "maintenance_fetcher.scheduler.datetime"
    ) as mock_datetime:

        # Mock current time: 2025-10-06 01:30:00 UTC (exactly at 1:30 AM)
        mock_now = datetime(2025, 10, 6, 1, 30, 0)
        mock_datetime.utcnow.return_value = mock_now

        scheduler = MaintenanceFetcherScheduler()
        seconds = scheduler._seconds_until_target_time()

        # Assert - should be 24 hours = 86400 seconds
        assert seconds == 86400


def test_seconds_until_target_time_month_boundary():
    """Test time calculation across month boundary (Jan 31 -> Feb 1)."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "maintenance_fetcher.scheduler.datetime"
    ) as mock_datetime:

        # Mock current time: 2025-01-31 02:00:00 UTC (after 1:30 AM on Jan 31)
        mock_now = datetime(2025, 1, 31, 2, 0, 0)
        mock_datetime.utcnow.return_value = mock_now

        scheduler = MaintenanceFetcherScheduler()
        seconds = scheduler._seconds_until_target_time()

        # Assert - should be 23.5 hours until Feb 1 01:30:00
        # Uses timedelta to handle month boundary correctly
        assert seconds == 84600


@pytest.mark.asyncio
async def test_run_maintenance_fetch_success():
    """Test successful maintenance fetch execution."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "maintenance_fetcher.scheduler.fetch_and_store_maintenance_data"
    ) as mock_fetch, patch("time.time") as mock_time:

        mock_fetch.return_value = {"status": "success", "records": 10}
        mock_time.side_effect = [1000.0, 1005.5]  # start and end time

        scheduler = MaintenanceFetcherScheduler()

        # Mock update methods
        scheduler._update_health_status = Mock()
        scheduler._update_last_run = Mock()

        await scheduler.run_maintenance_fetch()

        # Assert
        mock_fetch.assert_called_once()
        assert scheduler._update_health_status.call_count == 2
        scheduler._update_health_status.assert_any_call("running")
        scheduler._update_health_status.assert_any_call("idle")
        scheduler._update_last_run.assert_called_once()


@pytest.mark.asyncio
async def test_run_maintenance_fetch_failure():
    """Test maintenance fetch handles exceptions."""
    with patch("signal.signal"), patch("os.getenv"), patch(
        "maintenance_fetcher.scheduler.fetch_and_store_maintenance_data"
    ) as mock_fetch:

        mock_fetch.side_effect = Exception("Fetch failed")

        scheduler = MaintenanceFetcherScheduler()

        # Mock update methods
        scheduler._update_health_status = Mock()
        scheduler._update_last_run = Mock()

        # Should not raise exception
        await scheduler.run_maintenance_fetch()

        # Assert
        scheduler._update_health_status.assert_any_call("error")
        scheduler._update_last_run.assert_not_called()


