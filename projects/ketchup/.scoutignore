# .scoutignore — control what Scout indexes and how it ranks files.
#
# This file was auto-generated by Scout. Customize it for your repo.
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HOW IT WORKS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# There are three modes, controlled by section headers:
#
#   (default)       Lines before any header are IGNORE patterns.
#                   Matching files are excluded from indexing entirely.
#
#   [dampen:0.X]    Matching files are indexed but ranked lower.
#                   Score is multiplied by the factor (0.0–1.0).
#                   Use for code that exists but shouldn't dominate results.
#
#   [boost:X.X]     Matching files are ranked higher.
#                   Score is multiplied by the factor (≥ 1.0).
#                   Use for your most important source directories.
#
#   [ignore]        Switches back to ignore mode.
#
# Multiple sections stack multiplicatively:
#   [dampen:0.5] + [dampen:0.7] on the same file → score × 0.35
#   [boost:1.5]  + [dampen:0.5] on the same file → score × 0.75
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PATTERN SYNTAX (gitignore-style)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
#   *.ext            files ending with .ext (any directory)
#   **/*.ext         same as above (explicit recursive)
#   dir/             a directory and everything under it
#   path/to/thing    exact path prefix
#   **/name          a filename at any depth
#   **/dir/**/file   glob with ** for directory traversal
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ── IGNORE ─────────────────────────────────────────────────────────
# Files that should never appear in search results.
# Scout already excludes common binary formats (.png, .jpg, .woff, etc.)
# so you only need to add repo-specific patterns here.

# Example: build output and dependencies
# node_modules/
# target/
# dist/
# build/
# __pycache__/

# Example: lock files (large, not useful for search)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# Cargo.lock

# Example: generated code
# **/generated/
# **/*.generated.ts


# ── DAMPEN ─────────────────────────────────────────────────────────
# Files that should be indexed but ranked lower in results.
# Good candidates: vendored code, plugins, test fixtures, samples.

# Example: third-party or vendored code (rarely the answer you want)
# [dampen:0.3]
# vendor/
# third_party/
# plugins/

# Example: test data and fixtures (useful but not primary code)
# [dampen:0.4]
# testdata/
# fixtures/
# **/__snapshots__/

# Example: SDK/sample code (reference, not implementation)
# [dampen:0.4]
# sdk/
# samples/
# examples/

# Example: storybook stories and mocks
# [dampen:0.5]
# **/*.stories.tsx
# **/*.stories.ts
# **/mocks/


# ── BOOST ──────────────────────────────────────────────────────────
# Files that should rank higher than normal.
# Good candidates: your core source, main API surface, key configs.

# Example: core source code
# [boost:1.3]
# src/core/
# src/api/

# Example: important configuration
# [boost:1.2]
# src/config/


# ── BACK TO IGNORE ────────────────────────────────────────────────
# Use [ignore] to switch back to ignore mode after dampen/boost sections.
# [ignore]
