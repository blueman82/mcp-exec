{
  "name": "@justanothermldude/mcp-exec",
  "version": "1.3.0",
  "description": "MCP execution utilities for sandboxed code execution with OS-level isolation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsc --watch",
