    "test:integration": "vitest run tests/integration.test.ts"
  },
  "bin": {
    "mcp-exec": "dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.19",
    "@justanothermldude/meta-mcp-core": "^0.1.4",
