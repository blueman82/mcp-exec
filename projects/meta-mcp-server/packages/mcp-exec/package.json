    "esbuild": "^0.25.12",
    "get-port": "^7.1.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "^2025.12.18",
    "@types/node": "^20.19.31",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.11.7"
    }
  }
}
