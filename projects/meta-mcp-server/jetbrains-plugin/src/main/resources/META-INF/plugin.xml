<idea-plugin>
    <id>com.adobe.metamcp</id>
    <name>Meta-MCP</name>
    <version>1.0.0</version>
    <vendor email="support@adobe.com" url="https://github.com/Adobe-AIFoundations">Adobe</vendor>

    <description><![CDATA[
    <p>Meta-MCP Server Manager - Visual management for MCP (Model Context Protocol) servers.</p>

    <h3>Features</h3>
    <ul>
        <li><b>Servers Tab:</b> Manage servers in ~/.meta-mcp/servers.json</li>
        <li><b>Catalog Tab:</b> Browse and install MCP servers from the GitHub catalog</li>
        <li><b>Setup Tab:</b> Configure AI tools (Claude, Cursor, etc.) with meta-mcp</li>
    </ul>

    <h3>What is Meta-MCP?</h3>
    <p>Meta-MCP wraps multiple backend MCP servers, exposing only 3 meta-tools instead of
    loading 100+ tool schemas upfront. This reduces context token consumption for AI tools.</p>

    <h3>Getting Started</h3>
    <ol>
        <li>Open the Meta-MCP tool window (View → Tool Windows → Meta-MCP)</li>
        <li>Go to Setup tab and install meta-mcp-server</li>
        <li>Configure your AI tool (Claude, Cursor, etc.)</li>
        <li>Add servers from the Catalog or manually in Servers tab</li>
    </ol>
    ]]></description>

    <change-notes><![CDATA[
    <h3>1.0.0</h3>
    <ul>
        <li>Initial release</li>
        <li>Servers management (add, edit, delete)</li>
        <li>GitHub catalog browser</li>
        <li>AI tool configuration</li>
    </ul>
    ]]></change-notes>

    <idea-version since-build="241" until-build="253.*"/>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool Window -->
        <toolWindow id="Meta-MCP"
                    secondary="true"
                    anchor="right"
                    factoryClass="com.adobe.metamcp.ui.MetaMcpToolWindowFactory"
                    icon="/icons/meta-mcp.svg"/>

        <!-- Application-level services -->
        <applicationService
            serviceInterface="com.adobe.metamcp.services.ServersConfigService"
            serviceImplementation="com.adobe.metamcp.services.ServersConfigService"/>
        <applicationService
            serviceInterface="com.adobe.metamcp.services.CatalogService"
            serviceImplementation="com.adobe.metamcp.services.CatalogService"/>
        <applicationService
            serviceInterface="com.adobe.metamcp.services.AIToolConfigService"
            serviceImplementation="com.adobe.metamcp.services.AIToolConfigService"/>
        <applicationService
            serviceInterface="com.adobe.metamcp.services.LocalServerParser"
            serviceImplementation="com.adobe.metamcp.services.LocalServerParser"/>
        <applicationService
            serviceInterface="com.adobe.metamcp.services.RepoDownloader"
            serviceImplementation="com.adobe.metamcp.services.RepoDownloader"/>
        <applicationService
            serviceInterface="com.adobe.metamcp.services.RepoDetector"
            serviceImplementation="com.adobe.metamcp.services.RepoDetector"/>

        <!-- Notifications -->
        <notificationGroup id="Meta-MCP Notifications"
                          displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="MetaMcp.RefreshServers"
                class="com.adobe.metamcp.actions.RefreshServersAction"
                text="Refresh Servers"
                description="Reload servers from servers.json"/>
    </actions>
</idea-plugin>
