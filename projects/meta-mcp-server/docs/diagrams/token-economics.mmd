## API

```typescript
// Discover
await call_tool("list_servers", {});

// Summary
await call_tool("get_server_tools", {
  server_name: "jira",
  summary_only: true
});

// Full schema
await call_tool("get_server_tools", {
  server_name: "jira",
  tools: ["search_issues"]
});

// Execute
await call_tool("call_tool", {
  server_name: "jira",
  tool_name: "search_issues",
  arguments: { jql: "..." }
});
```
