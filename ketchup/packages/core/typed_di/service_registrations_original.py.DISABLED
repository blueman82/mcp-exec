        event_handler = await resolver.aget(SlackEventHandler)
        # Create clients dict for EventProcessor
        clients = {
            "slack_auth": slack_auth,
            "command_router": command_router,
            "event_handler": event_handler,
        }
        return EventProcessor(
            clients=clients,
            slack_auth=slack_auth,
            command_router=command_router,
            event_handler=event_handler,
        )

