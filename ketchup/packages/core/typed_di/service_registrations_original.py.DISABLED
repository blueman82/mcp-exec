        "Protocol definitions loaded successfully from analysis module (including DB protocols)"
    )
    # Some concrete services may not have generated protocols; provide safe aliases
    try:
        RestoreStateManagerProtocol  # type: ignore[name-defined]
    except NameError:  # pragma: no cover - executed only when protocol missing
        RestoreStateManagerProtocol = RestoreStateManager  # type: ignore[assignment]
except ImportError:
    logger.warning("Protocol definitions not available - using fallback protocols")
    PROTOCOLS_AVAILABLE = False
    # Fallback protocols are now defined at module level above for importability


