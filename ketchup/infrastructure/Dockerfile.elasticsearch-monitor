# Multi-stage build following existing pattern
FROM python:3.12-slim AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    gcc g++ make curl git \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy requirements - use main app requirements since monitor uses same dependencies
COPY infrastructure/requirements-app.txt /tmp/requirements.txt

# Install Python packages
RUN pip install --upgrade pip && \
    pip install wheel && \
    pip install -r /tmp/requirements.txt

# Stage 2: Runtime
FROM python:3.12-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy virtual environment
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

WORKDIR /app

# Copy application code
COPY packages/ ./packages/
COPY ketchup_elasticsearch_monitor/ ./ketchup_elasticsearch_monitor/

# Create log directory
RUN mkdir -p /var/log/elasticsearch_monitor

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

# Run the Elasticsearch monitor
CMD ["python", "/app/ketchup_elasticsearch_monitor/monitor.py"]