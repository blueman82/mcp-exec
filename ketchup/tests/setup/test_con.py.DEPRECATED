API_KEY = "<obtain this from Ketchup's Azure API Management>"
MAX_RETRIES = 5
NUM_CONNECTIONS = 1
MAX_TOKENS = 1024
ENCODING = tiktoken.get_encoding("o200k_base")

HEADERS = {"Content-Type": "application/json", "api-key": API_KEY}

# Use the real SecretsManager, assuming AWS credentials are configured in the environment
set_instance("secrets_manager", SecretsManager())


