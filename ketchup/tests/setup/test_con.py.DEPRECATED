async def fetch_slack_messages(slack_clients, channel_id: str) -> str:
    msg_ops = slack_clients["msg_ops"]
    all_messages = await msg_ops.fetch_channel_messages(channel_id)
    return "\n".join(all_messages)


async def openai_request(openai_handler, idx, input_text, input_tokens):
    """
    Makes a single request to the OpenAI handler and returns a result tuple.
    The OpenAIHandler is expected to perform its own retries.
    """
    start_time = time.time()
    messages = [
        {
            "role": "user",
            "content": f"Generate a detailed timeline of the Slack discussion. Include every significant event, comment, and mention, in bullet points. {input_text}",
        }
    ]
    try:
        # Single call to the handler, trusting its internal retry logic
        result = await openai_handler.call_openai_endpoint(messages=messages)

        # Process successful response
        if (
            "choices" in result
            and result["choices"]
            and result["choices"][0].get("message")
        ):
            output_text = result["choices"][0]["message"]["content"]
            output_tokens = len(ENCODING.encode(output_text))
            # OpenAIHandler's internal retries are not directly visible here for 'status'
            # We assume if it returns without error, it's a success from this function's perspective.
            # The handler itself would have logged its retries.
            status = "Success (Handler)"
            return (
                idx,
                status,
                time.time() - start_time,
                0.0,  # Retry delay is handled within OpenAIHandler
                input_tokens,
                output_tokens,
            )
        else:
            # Handle cases where the handler returns but it's not a structured success
            # (e.g., error in response structure, or an error object returned by the handler)
            error_detail = str(
                result.get("error", "Unknown error structure from handler")
            )
            # --- DIAGNOSTIC PRINT --- #
            print(
                f"\n--- DIAGNOSTIC: OpenAIHandler returned (idx: {idx}, deemed failure by test_con) ---"
            )
            print(f"Result type: {type(result)}")
            print(f"Result content: {result}")
            print(
                "------------------------------------------------------------------------------------\n"
            )
            # --- END DIAGNOSTIC PRINT --- #
            return (
                idx,
                f"Failed (Handler - No Choices/Error: {error_detail[:100]})",  # Truncate error
                time.time() - start_time,
                0.0,
                input_tokens,
                0,
            )
    except Exception as e:
        # Catch any exception raised by openai_handler.call_openai_endpoint
        # after its internal retries are exhausted.
        return (
            idx,
            f"Failed (Handler - Exception: {type(e).__name__})",
            time.time() - start_time,
            0.0,  # Retry delay is handled within OpenAIHandler
            input_tokens,
            0,
        )


async def main():
    slack_clients = None
    openai_handler = None
    result_path = None
    results = []
    error_info = None
    container_id = os.uname()[1]  # Hostname is container id
    result_path = f"/app/results/result-{container_id}.json"
    try:
        slack_clients = await initialize_slack_clients()
        openai_handler = await _create_openai_handler()
        print("Fetching messages from Slack...")
        input_text = await fetch_slack_messages(slack_clients, SLACK_CHANNEL_ID)
        input_tokens = len(ENCODING.encode(input_text))
        print(f"Fetched {input_tokens:,} input tokens from Slack.")
        start_time_all = time.time()
        tasks = [
            openai_request(openai_handler, i, input_text, input_tokens)
            for i in range(1, NUM_CONNECTIONS + 1)
        ]
        results = await asyncio.gather(*tasks)
        total_time = time.time() - start_time_all
        results = sorted(results, key=lambda x: x[0])

        total = len(results)
        total_successes = sum(1 for _, s, *_ in results if s == "Success (Handler)")
        failures = sum(
            1
            for _, s, *_ in results
            if isinstance(s, str) and s.startswith("Failed (Handler")
        )
        total_input_tokens = sum(inp for *_, inp, _ in results if inp is not None)
        total_output_tokens = sum(out for *_, _, out in results if out is not None)
        avg_time = sum(r[2] for r in results) / total if total > 0 else 0
        max_time = max(r[2] for r in results) if total > 0 else 0
        min_time = min(r[2] for r in results) if total > 0 else 0
        avg_retry_sleep = sum(r[3] for r in results) / total if total > 0 else 0

        table_data = [
            [idx, status, f"{elapsed:.2f}s", f"{sleep:.2f}s"]
            for idx, status, elapsed, sleep, _, _ in results
        ]
        print("\nConnection Results:")
        print(
            tabulate(
                table_data,
                headers=[
                    "Connection #",
                    "Status",
                    "Total Request Time",
                    "Retry Sleep Time",
                ],
                tablefmt="grid",
            )
        )

        print("\nSummary Table:")
        summary_table = [
            ["Total Successful", total_successes],
            ["Total Failed", failures],
            ["Total execution time", f"{total_time:.2f}s"],
            ["Average request time", f"{avg_time:.2f}s"],
            ["Fastest request", f"{min_time:.2f}s"],
            ["Slowest request", f"{max_time:.2f}s"],
            ["Average retry sleep time", f"{avg_retry_sleep:.2f}s"],
            ["Total input tokens", f"{total_input_tokens:,}"],
            ["Total output tokens", f"{total_output_tokens:,}"],
            ["Total tokens used", f"{total_input_tokens + total_output_tokens:,}"],
            [
                "Average total tokens per request",
                f"{(total_input_tokens + total_output_tokens) / total:,.2f}",
            ],
            ["Average input tokens per request", f"{total_input_tokens / total:,.2f}"],
            [
                "Average output tokens per request",
                f"{total_output_tokens / total:,.2f}",
            ],
        ]
        print(tabulate(summary_table, headers=["Metric", "Value"], tablefmt="grid"))

        print("\nSuccess Metrics Summary:")
        print(
            tabulate(
                [
                    ["Total Requests", total],
                    [
                        "Success Rate",
                        (
                            f"{(total_successes / total) * 100:.2f}%"
                            if total > 0
                            else "0.00%"
                        ),
                    ],
                    [
                        "Failure Rate",
                        f"{(failures / total) * 100:.2f}%" if total > 0 else "0.00%",
                    ],
                ],
                headers=["Metric", "Value"],
                tablefmt="grid",
            )
        )

        # Write results to file (success path)
        with open(result_path, "w") as f:
            json.dump(
                {
                    "container_id": container_id,
                    "results": results,
                    "summary": {
                        "total": total,
                        "total_successes": total_successes,
                        "failures": failures,
                        "total_time": total_time,
                        "avg_time": avg_time,
                        "max_time": max_time,
                        "min_time": min_time,
                        "avg_retry_sleep": avg_retry_sleep,
                        "total_input_tokens": total_input_tokens,
                        "total_output_tokens": total_output_tokens,
                    },
                },
                f,
                indent=2,
            )
    except Exception as e:
        # On any error, write a result file with error info
        error_info = {
            "container_id": container_id,
            "status": "error",
            "exception": str(e),
            "traceback": traceback.format_exc(),
        }
        with open(result_path, "w") as f:
            json.dump(error_info, f, indent=2)
        raise
    finally:
        if openai_handler:
            print("Cleaning up OpenAI handler...")
            await openai_handler.cleanup()
            print("OpenAI handler cleanup complete.")
        if slack_clients and slack_clients.get("session"):
            print("Closing Slack client session...")
            await slack_clients["session"].close()
            print("Slack client session closed.")
        try:
            await cleanup_resources()
        except Exception as e:
            print(f"[WARN] Error during fallback aiohttp cleanup: {e}")


if __name__ == "__main__":
    asyncio.run(main())
