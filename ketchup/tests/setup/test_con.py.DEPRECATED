#!/usr/bin/env python3
"""
Slack Channel Summarization Tester

Reads messages from a Slack channel using aiohttp, formats them as a single input,
and sends them to an Azure OpenAI-compatible API endpoint across 47 concurrent connections.

Handles:
- Slack API retries (no slack_sdk required)
- OpenAI endpoint retries (with exponential backoff)
- Downloads Slack snippet contents if available
- Detailed success/failure/timing/token metrics

Requirements:
- aiohttp
- asyncio
- tiktoken
- tabulate
- client.py (custom retry client)
"""

import asyncio
import json
import os
import time
import traceback

# Set AWS environment variables for the script's execution context
os.environ["AWS_PROFILE"] = "campaign_prod_v7"
os.environ["AWS_DEFAULT_REGION"] = "eu-west-1"

import tiktoken
from tabulate import tabulate

