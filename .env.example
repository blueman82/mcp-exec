# Meta-MCP Server Environment Variables
# Copy this file to .env and fill in your values

# Path to your servers.json configuration
SERVERS_CONFIG=/path/to/.meta-mcp/servers.json

# Optional: Backend PATs for Gateway integration
# These can also be configured in servers.json via backendAuth or backendAuthEnvFile
JIRA_PAT=your-jira-pat-here
GITHUB_PAT=your-github-pat-here
